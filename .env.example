# ==============================================================================
# harness-bootstrap .env.example
# OPERATOR ACTION: cp .env.example .env  then fill in real values
# This is the ONLY file you need to edit before running: sudo bash install.sh
# ==============================================================================

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Your Tailscale auth key (from https://login.tailscale.com/admin/settings/keys)
TAILSCALE_AUTH_KEY=tskey-auth-REPLACE_ME

# Linux username of the primary operator (must be UID 1000)
HOST_USER=ryan

# Ollama model to pull and use (must match ai-agent-harness CURRENT-STATE.md)
OLLAMA_MODEL=gemma4:31b

# ── OPTIONAL — defaults are correct for standard install ──────────────────────

# Tailscale node hostname (visible in tailnet admin panel)
TAILSCALE_HOSTNAME=harness-host

# n8n web UI port
N8N_PORT=5678

# n8n persistent data directory on host
N8N_DATA_DIR=/home/ryan/.local/share/n8n

# Ollama bind address (don't change unless you know why)
OLLAMA_HOST=0.0.0.0:11434
